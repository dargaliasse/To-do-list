from sqlalchemy import create_engine, Column, Integer, String, Date
from sqlalchemy.orm import declarative_base, sessionmaker
from datetime import datetime, timedelta, date

Base = declarative_base()


class Task(Base):
    __tablename__ = "task"

    id = Column(Integer, primary_key=True)
    task = Column(String)
    deadline = Column(Date, default=date.today)


engine = create_engine("sqlite:///todo.db?check_same_thread=False")
Base.metadata.create_all(engine)

Session = sessionmaker(bind=engine)
session = Session()


def get_today_tasks():
    today = date.today()
    return session.query(Task).filter(Task.deadline == today).all()


def get_week_tasks():
    today = date.today()
    week_tasks = []

    for i in range(7):
        day = today + timedelta(days=i)
        tasks = session.query(Task).filter(Task.deadline == day).all()
        week_tasks.append((day, tasks))

    return week_tasks


def get_all_tasks():
    return session.query(Task).order_by(Task.deadline).all()


def get_missed_tasks():
    today = date.today()
    return session.query(Task).filter(Task.deadline < today).order_by(Task.deadline).all()


def add_task(task_text, deadline_input):
    deadline_date = datetime.strptime(deadline_input, "%Y-%m-%d").date()
    new_task = Task(task=task_text, deadline=deadline_date)
    session.add(new_task)
    session.commit()


def delete_task(task_number):
    tasks = get_all_tasks()
    task_to_delete = tasks[task_number - 1]
    session.delete(task_to_delete)
    session.commit()


def exit_program():
    print("Bye!")
    session.close()


def main():
    while True:
        print("""1) Today's tasks
2) Week's tasks
3) All tasks
4) Missed tasks
5) Add a task
6) Delete a task
0) Exit""")
        user_input = input()

        if user_input == "1":
            tasks = get_today_tasks()
            print(f"\nToday {date.today().strftime('%d %b')}")
            if not tasks:
                print("Nothing to do!")
            else:
                for i, task in enumerate(tasks, 1):
                    print(f"{i}. {task.task}")
            print()

        elif user_input == "2":
            week_tasks = get_week_tasks()
            print()
            for day, tasks in week_tasks:
                print(day.strftime("%A %d %b"))
                if not tasks:
                    print("Nothing to do!")
                else:
                    for i, task in enumerate(tasks, 1):
                        print(f"{i}. {task.task}")
                print()

        elif user_input == "3":
            tasks = get_all_tasks()
            print("\nAll tasks:")
            if not tasks:
                print("Nothing to do!")
            else:
                for i, task in enumerate(tasks, 1):
                    print(f"{i}. {task.task}. {task.deadline.strftime('%d %b')}")
            print()

        elif user_input == "4":
            tasks = get_missed_tasks()
            print("\nMissed tasks:")
            if not tasks:
                print("All tasks have been completed!")
            else:
                for i, task in enumerate(tasks, 1):
                    print(f"{i}. {task.task}. {task.deadline.strftime('%d %b')}")
            print()

        elif user_input == "5":
            task_text = input("\nEnter task:\n")
            deadline_input = input("Enter deadline:\n")
            add_task(task_text, deadline_input)
            print("The task has been added!\n")

        elif user_input == "6":
            tasks = get_all_tasks()
            print("\nChoose the number of the task you want to delete:")
            if not tasks:
                print("Nothing to delete!\n")
            else:
                for i, task in enumerate(tasks, 1):
                    print(f"{i}. {task.task}. {task.deadline.strftime('%d %b')}")
                task_number = int(input())
                delete_task(task_number)
                print("The task has been deleted!\n")

        elif user_input == "0":
            print("\nBye!")
            session.close()
            break


main()
